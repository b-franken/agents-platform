# Azure AI Foundry
AZURE_AI_PROJECT_ENDPOINT=https://<your-project>.services.ai.azure.com/api/projects/<project-id>
AZURE_OPENAI_RESPONSES_DEPLOYMENT_NAME=gpt-4.1
# AZURE_OPENAI_API_KEY=

# RAG — created by: uv run python -m agent_core.knowledge upload
# VECTOR_STORE_ID=

# Checkpointing — persistent workflow state
CHECKPOINT_STORAGE_PATH=./checkpoints

# Remote A2A agents — format: name=url,name=url
# A2A_AGENTS=legal=https://legal.internal/a2a,finance=https://finance.internal/a2a

# Observability
ENABLE_INSTRUMENTATION=false
ENABLE_CONSOLE_EXPORTERS=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
